# 4. Monte Carlo Tree Search Path Planner (Outer Loop)
# =============================================================================

class MCTSNode:
    """Node representing discrete path selection states in tree space."""
    def __init__(self, state, parent=None):
        self.state = state
        self.parent = parent
        self.children = {}
        self.visits = 0
        self.reward = 0.0

class MCTSTSPPlanner:
    """Path planner designed to solve TV-TSP over denied networks."""
    def __init__(self, num_targets=NUM_TARGETS):
        self.num_targets = num_targets
        self.cost_matrix = np.random.uniform(1.0, 5.0, (num_targets, num_targets))
        np.fill_diagonal(self.cost_matrix, 0)

    def search_next_node(self, current_route, iterations=MCTS_ITERATIONS):
        """Resolves the next target sequence using randomized tree-policy lookahead."""
        # Trigger dynamic anti-analysis guard prior to core algorithmic calculation
        enforce_integrity_shields()
        
        root = MCTSNode(state=list(current_route))
        
        for _ in range(iterations):
            node = root
            # 1. Selection Phase
            while node.children and len(node.children) == (self.num_targets - len(node.state)):
                if node.visits == 0:
                    break
                log_parent_visits = np.log(node.visits + 1e-6)
                best_val = -float('inf')
                best_child = None
                for child in node.children.values():
                    ucb_val = (child.reward / (child.visits + 1e-6)) + 1.414 * np.sqrt(log_parent_visits / (child.visits + 1e-6))
                    if ucb_val > best_val:
                        best_val = ucb_val
                        best_child = child
                node = best_child
                if not node: 
                    break

            # 2. Expansion Phase
            remaining = [t for t in range(self.num_targets) if t not in node.state]
            if remaining:
                next_target = random.choice(remaining)
                new_state = node.state + [next_target]
                if next_target not in node.children:
                    child_node = MCTSNode(state=new_state, parent=node)
                    node.children[next_target] = child_node
                    node = child_node

            # 3. Simulation Phase (Rollout)
            rollout_state = list(node.state)
            while len(rollout_state) < self.num_targets:
                unvisited = [t for t in range(self.num_targets) if t not in rollout_state]
                rollout_state.append(random.choice(unvisited))
            
            total_cost = 0.0
            for idx in range(len(rollout_state) - 1):
                total_cost += self.cost_matrix[rollout_state[idx], rollout_state[idx+1]]
            
            reward = 1.0 / (total_cost + 1e-6)

            # 4. Backpropagation Phase
            curr = node
            while curr is not None:
                curr.visits += 1
                curr.reward += reward
                curr = curr.parent

        if not root.children:
            remaining = [t for t in range(self.num_targets) if t not in current_route]
            return remaining[0] if remaining else 0
            
        best_target = max(root.children.items(), key=lambda item: item[1].visits)[0]
        return best_target


