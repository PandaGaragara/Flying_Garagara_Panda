# 5. Analytical QP Solver
# =============================================================================

def solve_analytical_qp(u_nominal, A_cbf, b_cbf, u_min=U_MIN, u_max=U_MAX):
    """
    Solves 1D Convex QP analytically under linear inequality bounds.
    Optimizes: min 1/2 * (u - u_nominal)^2
    Subject to: A_cbf * u <= b_cbf and u_min <= u <= u_max
    """
    u_star = u_nominal
    if A_cbf * u_star > b_cbf:
        if abs(A_cbf) > 1e-9:
            u_star = b_cbf / A_cbf
            
    # Actuator protection saturation limits
    u_star = max(u_min, min(u_max, u_star))
    return u_star


