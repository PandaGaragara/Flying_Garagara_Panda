def init_database():
    """Builds the SQLite schema structure for telemetry flight logging."""
    conn = sqlite3.connect(DB_NAME)
    cursor = conn.cursor()
    cursor.execute("""
        CREATE TABLE IF NOT EXISTS flight_logs (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            test_group TEXT,
            step INTEGER,
            true_threat REAL,
            estimated_threat REAL,
            p_min_used REAL,
            is_blocked INTEGER,
            latency_sec REAL
        )
    """)
    conn.commit()
    conn.close()

